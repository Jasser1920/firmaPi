{% extends 'base.html.twig' %}

{% block title %}Reclammation index{% endblock %}

{% block body %}
    <h1>Reclammation index</h1>

    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Description</th>
                <th>Status</th>
                <th>actions</th>
            </tr>
        </thead>
        <tbody>
        {% for reclammation in reclammations %}
            <tr>
                <td>{{ reclammation.id }}</td>
                <td>{{ reclammation.description }}</td>
                <td>{{ reclammation.status.value }}</td>

                <td>
                    <a href="{{ path('app_reclammation_show', {'id': reclammation.id}) }}">show</a>
                    <a href="{{ path('app_reclammation_edit', {'id': reclammation.id}) }}">edit</a>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">no records found</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <a href="{{ path('app_reclammation_new') }}">Create new</a>
{% endblock %}
