{% extends 'base.html.twig' %}

{% block title %}Produit Index{% endblock %}

{% block body %}
    <div class="container mt-4">
        <div class="card shadow">
            <div class="card-header bg-success text-white">
                <h1 class="mb-0">Produit Index</h1>
            </div>
            <div class="card-body">
                <table class="table table-hover">
                    <thead class="thead-light">
                        <tr>
                            <th>Id</th>
                            <th>Nom</th>
                            <th>Description</th>
                            <th>Image</th>
                            <th>Quantité</th>
                            <th>Unité</th>
                            <th>Prix</th>
                            <th>Date d'Expiration</th>
                            <th>Agriculteur</th>
                            <th>Catégorie</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                    {% for produit in produits %}
                        <tr>
                            <td>{{ produit.id }}</td>
                            <td>{{ produit.nom }}</td>
                            <td>{{ produit.description }}</td>
                            <td>{{ produit.image }}</td>
                            <td>{{ produit.quantite }}</td>
                            <td>{{ produit.unite }}</td>
                            <td>{{ produit.prix }}</td>
                            <td>{{ produit.dateExp ? produit.dateExp|date('Y-m-d') : '' }}</td>
                            <td>{{ produit.agriculteur.id }}</td>
                            <td>{{ produit.categorie.id }}</td>
                            <td>
                                <a href="{{ path('app_produit_show', {'id': produit.id}) }}" class="btn btn-info btn-sm">Show</a>
                                <a href="{{ path('app_produit_edit', {'id': produit.id}) }}" class="btn btn-warning btn-sm">Edit</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="11" class="text-center">No records found</td>
                        </tr>
                    {% endfor %}
                    </tbody>
                </table>

                <div class="mt-3">
                    <a href="{{ path('app_produit_new') }}" class="btn btn-success">Create New</a>
                </div>
            </div>
        </div>
    </div>
{% endblock %}